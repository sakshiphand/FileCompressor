    background-color: #E2E8F0;
    text-align: center;
    min-height: 18px;
    color: #1F2937;
    font-weight: 600;
}

QProgressBar::chunk {
    background-color: #2563EB;
    border-radius: 6px;
}

QGroupBox {
    background-color: white;
    border: 1px solid #D1D5DB;
    border-radius: 12px;
    margin-top: 18px;
    padding: 15px;
    font-size: 14px;
    font-weight: bold;
    color: #111827;
}

QGroupBox::title {
    subcontrol-origin: margin;
    subcontrol-position: top center;
    padding: 0px 10px;
}

